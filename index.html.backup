<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Kudakwashe Taderera - Portfolio showcasing web development, AI integration, and application security projects">
  <meta name="keywords" content="Kudakwashe Taderera, portfolio, web development, UIUC">
  <meta name="author" content="Kudakwashe Taderera">
  
  <title>Kudakwashe Taderera | Portfolio</title>
  
  <!-- Favicon -->
  <link rel="icon" type="image/png" href="/portfolio/assets/favicon.png">
  
  <!-- Open Graph / Facebook -->
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://yourwebsite.com/portfolio/">
  <meta property="og:title" content="Kudakwashe Taderera | Portfolio">
  <meta property="og:description" content="Technology professional with expertise in software development, project management, and systems integration. Currently pursuing a Master of Science in Technology Management at University of Illinois Urbana-Champaign.">
  <meta property="og:image" content="/portfolio/assets/meta-image.jpg">
  
  <!-- Twitter -->
  <meta property="twitter:card" content="summary_large_image">
  <meta property="twitter:url" content="https://yourwebsite.com/portfolio/">
  <meta property="twitter:title" content="Kudakwashe Taderera | Portfolio">
  <meta property="twitter:description" content="Technology professional with expertise in software development, project management, and systems integration.">
  <meta property="twitter:image" content="/portfolio/assets/meta-image.jpg">
  
  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  
  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  
  <!-- Custom CSS -->
  <link rel="stylesheet" href="/portfolio/css/styles.css">
</head>
<body class="transition-fade">
  <!-- Navbar -->
  <nav class="navbar">
    <div class="container navbar-container">
      <a href="/portfolio/" class="navbar-logo">Kudakwashe <span>Taderera</span></a>
      
      <button class="mobile-menu-btn" aria-label="Toggle menu" aria-expanded="false">
        <i class="fas fa-bars"></i>
      </button>
      
      <ul class="navbar-nav">
        <li><a href="/portfolio/" class="nav-link">Home</a></li>
        <li><a href="/portfolio/pages/about.html" class="nav-link">About</a></li>
        <li><a href="/portfolio/pages/projects.html" class="nav-link">Projects</a></li>
        <li><a href="/portfolio/pages/resume.html" class="nav-link">Resume</a></li>
        <li><a href="/portfolio/pages/contact.html" class="nav-link">Contact</a></li>
      </ul>
    </div>
  </nav>
  
  <!-- Hero Section -->
  <section class="hero">
    <div class="container">
      <div class="hero-content">
        <div class="hero-text">
          <h1 class="fade-in">
            Hi, I'm <span class="gradient-heading">Kudakwashe Taderera</span>
          </h1>
          <div class="section-divider fade-in delay-100"></div>
          <p class="fade-in delay-200 accent-border-left">
            I'm a <span class="txt-type" data-wait="3000" data-words='["Software Developer", "Technology Manager", "Problem Solver", "Innovation Enthusiast"]'></span> passionate about creating elegant solutions to complex problems. Currently pursuing my Master of Science in Technology Management at the University of Illinois Urbana-Champaign.
          </p>
          <div class="fade-in delay-300" style="margin-top: 2rem;">
            <a href="/portfolio/pages/contact.html" class="btn btn-primary">
              <i class="fas fa-paper-plane btn-icon"></i> Get in Touch
            </a>
            <a href="/portfolio/pages/projects.html" class="btn btn-outline" style="margin-left: 1rem;">
              <i class="fas fa-laptop-code btn-icon"></i> View Projects
            </a>
          </div>
        </div>
        <div class="hero-image slide-in-right">
          <img src="/portfolio/assets/profile.svg" alt="Kudakwashe Taderera" class="hover-scale">
        </div>
      </div>
    </div>
  </section>
  
  <!-- About Summary Section -->
  <section class="about">
    <div class="container">
      <h2 class="text-center gradient-heading fade-in">About Me</h2>
      <div class="section-divider fade-in delay-100" style="margin: 0 auto 3rem;"></div>
      
      <div class="about-grid">
        <div class="about-image fade-in delay-200">
          <img src="/portfolio/assets/profile.svg" alt="Kudakwashe Taderera">
        </div>
        <div class="about-content fade-in delay-300">
          <div class="about-bio">
            <h3 class="gradient-heading">Tech Professional & Student</h3>
            <p>
              As a technology enthusiast pursuing a Master of Science in Technology Management at UIUC, I combine technical expertise with strategic business knowledge to deliver impactful solutions.
            </p>
            <p>
              My background includes experience in software development, project management, and systems integration, with a focus on creating user-centered applications that solve real-world problems.
            </p>
            <a href="/portfolio/pages/about.html" class="btn btn-outline">
              <i class="fas fa-user btn-icon"></i> Learn More
            </a>
          </div>
          
          <div class="skills">
            <h3 class="skills-title">
              <i class="fas fa-code"></i> Technical Skills
            </h3>
            
            <div class="skill-item fade-in delay-400">
              <div class="skill-info">
                <span class="skill-name">Frontend Development</span>
                <span class="skill-percentage">90%</span>
              </div>
              <div class="skill-progress-bg">
                <div class="skill-progress-fill" data-percentage="90"></div>
              </div>
            </div>
            
            <div class="skill-item fade-in delay-500">
              <div class="skill-info">
                <span class="skill-name">Backend Development</span>
                <span class="skill-percentage">85%</span>
              </div>
              <div class="skill-progress-bg">
                <div class="skill-progress-fill" data-percentage="85"></div>
              </div>
            </div>
            
            <div class="skill-item fade-in delay-500">
              <div class="skill-info">
                <span class="skill-name">Database Management</span>
                <span class="skill-percentage">80%</span>
              </div>
              <div class="skill-progress-bg">
                <div class="skill-progress-fill" data-percentage="80"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Featured Projects Section -->
  <section class="projects" style="background-color: var(--uiuc-blue-light);">
    <div class="container">
      <h2 class="text-center gradient-heading fade-in">Featured Projects</h2>
      <div class="section-divider fade-in delay-100" style="margin: 0 auto 3rem;"></div>
      
      <div class="projects-grid">
        <!-- Project 1 -->
        <div class="project-card fade-in delay-200">
          <div class="project-image">
            <img src="/portfolio/assets/career-guidance-system.svg" alt="Career Guidance System">
          </div>
          <div class="project-header">
            <h3 class="project-title">Career Guidance System</h3>
            <p class="project-subtitle">AI-powered career exploration platform</p>
          </div>
          <div class="project-content">
            <p class="project-description">
              An AI-powered platform designed to assist students and professionals in choosing the right career path based on education, interests, and job market trends.
            </p>
            
            <div class="project-highlights">
              <h4 class="highlights-title">
                <i class="fas fa-lightbulb"></i> Key Highlights
              </h4>
              <ul class="highlights-list">
                <li class="highlight-item">
                  <i class="fas fa-check-circle highlight-icon"></i>
                  <span>Personalized career & university program recommendations</span>
                </li>
                <li class="highlight-item">
                  <i class="fas fa-check-circle highlight-icon"></i>
                  <span>AI-driven career matching & industry insights</span>
                </li>
                <li class="highlight-item">
                  <i class="fas fa-check-circle highlight-icon"></i>
                  <span>Real-time job market demand trends & salary projections</span>
                </li>
              </ul>
            </div>
            
            <div>
              <h4 class="technologies-title">
                <i class="fas fa-code"></i> Technologies
              </h4>
              <div class="technologies-list">
                <span class="tech-badge">React.js</span>
                <span class="tech-badge">Node.js</span>
                <span class="tech-badge">TensorFlow</span>
                <span class="tech-badge">MongoDB</span>
                <span class="tech-badge">Express</span>
              </div>
            </div>
          </div>
          <div class="project-footer">
            <a href="https://github.com/kudakwashe-taderera" class="btn btn-outline" target="_blank" rel="noopener noreferrer">
              <i class="fab fa-github btn-icon"></i> Code
            </a>
            <a href="#" class="btn btn-primary" target="_blank" rel="noopener noreferrer">
              <i class="fas fa-external-link-alt btn-icon"></i> Demo
            </a>
          </div>
        </div>
        
        <!-- Project 2 -->
        <div class="project-card fade-in delay-300">
          <div class="project-image">
            <img src="/portfolio/assets/smart-home-automation.svg" alt="Smart Home Automation">
          </div>
          <div class="project-header">
            <h3 class="project-title">Smart Home Automation</h3>
            <p class="project-subtitle">IoT-based home control system</p>
          </div>
          <div class="project-content">
            <p class="project-description">
              A comprehensive IoT solution that enables users to monitor and control various aspects of their home environment through an intuitive mobile and web interface.
            </p>
            
            <div class="project-highlights">
              <h4 class="highlights-title">
                <i class="fas fa-lightbulb"></i> Key Highlights
              </h4>
              <ul class="highlights-list">
                <li class="highlight-item">
                  <i class="fas fa-check-circle highlight-icon"></i>
                  <span>Real-time monitoring and control of home devices</span>
                </li>
                <li class="highlight-item">
                  <i class="fas fa-check-circle highlight-icon"></i>
                  <span>Energy usage analytics and optimization</span>
                </li>
                <li class="highlight-item">
                  <i class="fas fa-check-circle highlight-icon"></i>
                  <span>Voice command integration with AI assistants</span>
                </li>
              </ul>
            </div>
            
            <div>
              <h4 class="technologies-title">
                <i class="fas fa-code"></i> Technologies
              </h4>
              <div class="technologies-list">
                <span class="tech-badge">React Native</span>
                <span class="tech-badge">Python</span>
                <span class="tech-badge">MQTT</span>
                <span class="tech-badge">Raspberry Pi</span>
                <span class="tech-badge">Firebase</span>
              </div>
            </div>
          </div>
          <div class="project-footer">
            <a href="https://github.com/kudakwashe-taderera" class="btn btn-outline" target="_blank" rel="noopener noreferrer">
              <i class="fab fa-github btn-icon"></i> Code
            </a>
            <a href="#" class="btn btn-primary" target="_blank" rel="noopener noreferrer">
              <i class="fas fa-external-link-alt btn-icon"></i> Demo
            </a>
          </div>
        </div>
        
        <!-- Project 3 -->
        <div class="project-card fade-in delay-400">
          <div class="project-image">
            <img src="/portfolio/assets/blockchain-supply-chain.svg" alt="Blockchain Supply Chain">
          </div>
          <div class="project-header">
            <h3 class="project-title">Blockchain Supply Chain</h3>
            <p class="project-subtitle">Decentralized tracking system</p>
          </div>
          <div class="project-content">
            <p class="project-description">
              A blockchain-based supply chain management system that provides transparency, traceability, and security for product movements from manufacturer to consumer.
            </p>
            
            <div class="project-highlights">
              <h4 class="highlights-title">
                <i class="fas fa-lightbulb"></i> Key Highlights
              </h4>
              <ul class="highlights-list">
                <li class="highlight-item">
                  <i class="fas fa-check-circle highlight-icon"></i>
                  <span>End-to-end product tracking with QR code integration</span>
                </li>
                <li class="highlight-item">
                  <i class="fas fa-check-circle highlight-icon"></i>
                  <span>Smart contracts for automated compliance verification</span>
                </li>
                <li class="highlight-item">
                  <i class="fas fa-check-circle highlight-icon"></i>
                  <span>Real-time analytics dashboard for supply chain insights</span>
                </li>
              </ul>
            </div>
            
            <div>
              <h4 class="technologies-title">
                <i class="fas fa-code"></i> Technologies
              </h4>
              <div class="technologies-list">
                <span class="tech-badge">Ethereum</span>
                <span class="tech-badge">Solidity</span>
                <span class="tech-badge">Web3.js</span>
                <span class="tech-badge">React</span>
                <span class="tech-badge">Node.js</span>
              </div>
            </div>
          </div>
          <div class="project-footer">
            <a href="https://github.com/kudakwashe-taderera" class="btn btn-outline" target="_blank" rel="noopener noreferrer">
              <i class="fab fa-github btn-icon"></i> Code
            </a>
            <a href="#" class="btn btn-primary" target="_blank" rel="noopener noreferrer">
              <i class="fas fa-external-link-alt btn-icon"></i> Demo
            </a>
          </div>
        </div>
      </div>
      
      <div class="text-center" style="margin-top: 3rem;">
        <a href="/portfolio/pages/projects.html" class="btn btn-primary">
          <i class="fas fa-th-large btn-icon"></i> View All Projects
        </a>
      </div>
    </div>
  </section>
  
  <!-- Testimonials Section -->
