    </div>
  </section>
  
  <!-- Call to Action -->
  <section class="cta" style="text-align: center; padding: 5rem 0; background-color: #fff;">
    <div class="container">
      <h2 class="gradient-heading fade-in">Interested in Working Together?</h2>
      <div class="section-divider fade-in delay-100" style="margin: 1rem auto 2rem;"></div>
      <p class="fade-in delay-200" style="max-width: 600px; margin: 0 auto 2rem;">
        I'm always open to discussing new projects, opportunities, or partnerships. Let's connect and see how we can work together to bring your ideas to life.
      </p>
      <a href="/portfolio/pages/contact.html" class="btn btn-primary btn-lg fade-in delay-300">
        <i class="fas fa-envelope btn-icon"></i> Get in Touch
      </a>
    </div>
